{
  "name": "toptracker-sdk",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for the TopTracker API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cd .. && husky typescript/.husky",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@10.23.0",
  "keywords": [
    "toptracker",
    "toptal",
    "time-tracking",
    "api",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AliSajjadRizavi/toptracker-sdk",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/AliSajjadRizavi/toptracker-sdk/issues"
  },
  "homepage": "https://github.com/AliSajjadRizavi/toptracker-sdk/tree/main/typescript#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  }
}
